# FOXINBURG EBOS — example environment configuration
# Copy to .env.development and fill in real values

NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=foxinburg
DB_PASSWORD=change_me
DB_NAME=foxinburg
DATABASE_URL=postgresql+asyncpg://foxinburg:change_me@localhost:5432/foxinburg

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me
REDIS_URL=redis://:change_me@localhost:6379

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=change-me-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Platform
PLATFORM_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=False
FROM_EMAIL=noreply@foxinburg.ru
FROM_NAME=FOXINBURG

# Teacher Academy / Yandex.Disk
YANDEX_DISK_TOKEN=
YANDEX_DISK_PUBLIC_FOLDER=

# AI Assistant / YandexGPT
YANDEXGPT_API_KEY=
YANDEXGPT_FOLDER_ID=

# Telegram notifications
TELEGRAM_BOT_TOKEN=

# Password encryption (Fernet key). Used to store reversible encrypted passwords for admin view.
# Generate key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PASSWORD_ENCRYPTION_KEY=
