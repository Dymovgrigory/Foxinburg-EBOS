# FOXINBURG EBOS — example environment configuration
# Copy to .env.development and fill in real values

NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=foxinburg
DB_PASSWORD=change_me
DB_NAME=foxinburg
DATABASE_URL=postgresql+asyncpg://foxinburg:change_me@localhost:5432/foxinburg

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me
REDIS_URL=redis://:change_me@localhost:6379

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=change-me-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Platform
PLATFORM_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=False
FROM_EMAIL=noreply@foxinburg.ru
FROM_NAME=FOXINBURG
