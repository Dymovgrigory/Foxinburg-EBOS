# Environment
NODE_ENV=production

# PostgreSQL
POSTGRES_USER=foxinburg
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_DB=foxinburg

# Redis
REDIS_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# JWT / secrets (use long random strings, e.g. openssl rand -hex 32)
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_STRING
JWT_REFRESH_SECRET=REPLACE_WITH_LONG_RANDOM_STRING

# Content protection for Teacher Academy materials
CONTENT_TOKEN_SECRET=REPLACE_WITH_LONG_RANDOM_STRING

# Password encryption for admin reversible password view
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PASSWORD_ENCRYPTION_KEY=REPLACE_WITH_FERNET_KEY

# AI Assistant / YandexGPT
YANDEXGPT_API_KEY=
YANDEXGPT_FOLDER_ID=

# Yandex Object Storage (S3-compatible)
S3_ENDPOINT=https://storage.yandexcloud.net
S3_REGION=ru-central1
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=
